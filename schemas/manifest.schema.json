{
  "$id": "https://education.splunk.com/schemas/edu-md2cd/manifest.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "edu-md2cd Course Manifest",
  "description": "Configuration for converting Markdown course descriptions to PDF",
  "type": "object",
  "required": ["metadata"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["projectId", "courseTitle", "splunk"],
      "properties": {
        "projectId": {
          "type": "string",
          "description": "Internal project identifier for development tracking (required)"
        },
        "courseId": {
          "type": "string",
          "description": "Course identifier (e.g., 'EDU-1001', '1234') - generated upon course completion"
        },
        "courseTitle": {
          "type": "string",
          "minLength": 1,
          "description": "Full course title"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$",
          "description": "URL-friendly course identifier"
        },
        "description": {
          "type": "string",
          "description": "Brief course description"
        },
        "courseDeveloper": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          ],
          "description": "Course developer name(s)"
        },
        "format": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["eLearning", "eLearning with lab exercises", "Instructor-led", "Instructor-led training", "Instructor-led with lab exercises", "Lab exercises only"],
                "description": "Course delivery mode"
              },
              "duration": {
                "type": "string",
                "description": "Course duration for this format (e.g., '18 hour(s)', '5 hour(s)')"
              }
            }
          },
          "minItems": 1,
          "description": "Course formats with mode and optional duration"
        },
        "audience": {
          "type": "object",
          "properties": {
            "role": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Target roles for this course"
            },
            "internal": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Internal audience segments"
            },
            "external": {
              "type": "array",
              "items": { "type": "string" },
              "description": "External audience segments"
            }
          }
        },
        "prerequisites": {
          "type": "object",
          "required": ["courses"],
          "properties": {
            "courses": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Required prerequisite courses (must be from validated list)"
            },
            "competencies": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Skills, knowledge, or competencies students should have"
            }
          },
          "description": "Course prerequisites and recommended competencies"
        },
        "ga": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "General availability date (YYYY-MM-DD)"
        },
        "updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Last update date (YYYY-MM-DD)"
        },
        "splunk": {
          "type": "object",
          "required": ["platform"],
          "properties": {
            "platform": {
              "type": "object",
              "required": ["version"],
              "properties": {
                "deployment": {
                  "type": "string",
                  "description": "Deployment type (e.g., 'Cloud', 'Enterprise')"
                },
                "version": {
                  "type": "string",
                  "description": "Splunk version (e.g., '9.4', '10.2.1')"
                }
              }
            }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Plugin name (must match directory in plugins/)"
              },
              "translations": {
                "type": "object",
                "description": "Key-value pairs for translation overrides",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        ]
      },
      "description": "Plugins to load for processing"
    },
    "input": {
      "type": "object",
      "properties": {
        "courseDescription": {
          "type": "string",
          "description": "Custom path to course description markdown file"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "description": "Theme name (defaults to 'splunk-edu')"
        },
        "destination": {
          "type": "string",
          "description": "Custom output directory path"
        },
        "pdfs": {
          "type": "object",
          "properties": {
            "courseDescription": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Custom filename for course description PDF (single format)"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["mode", "title"],
                    "properties": {
                      "mode": {
                        "type": "string",
                        "description": "Mode matching metadata.format[].mode"
                      },
                      "title": {
                        "type": "string",
                        "description": "Custom PDF filename for this mode"
                      }
                    }
                  },
                  "description": "Custom filenames per format mode"
                }
              ]
            }
          }
        }
      }
    }
  }
}
