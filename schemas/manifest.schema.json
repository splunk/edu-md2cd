{
  "$id": "https://education.splunk.com/schemas/edu-md2cd/manifest.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "edu-md2cd Course Manifest",
  "description": "Configuration for converting Markdown course descriptions to PDF",
  "type": "object",
  "required": ["metadata"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["courseId", "courseTitle", "splunk"],
      "properties": {
        "projectId": {
          "type": "string",
          "description": "Internal project identifier for development tracking"
        },
        "courseId": {
          "type": "string",
          "description": "Course identifier (e.g., 'splunk-course', '1234')"
        },
        "lmsId": {
          "type": "string",
          "description": "Learning Management System identifier (e.g., 'EDU-1234')"
        },
        "courseTitle": {
          "type": "string",
          "minLength": 1,
          "description": "Full course title"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$",
          "description": "URL-friendly course identifier"
        },
        "description": {
          "type": "string",
          "description": "Brief course description"
        },
        "courseDeveloper": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          ],
          "description": "Course developer name(s)"
        },
        "format": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["Instructor-led training", "eLearning", "eLearning with lab exercises", "Blended", "Lab experience"],
                "description": "Course delivery mode (must match exactly)"
              },
              "duration": {
                "type": "string",
                "pattern": "^(1(\\.0+)? hour|(0(\\.\\d+)?|([2-9]|[1-9]\\d+)(\\.\\d+)?|1\\.\\d*[1-9]\\d*) hours)$",
                "description": "Course duration (e.g., '1 hour', '5 hours', '13.5 hours'). Use 'hour' for values <= 1, 'hours' for values > 1"
              }
            }
          },
          "minItems": 1,
          "description": "Course formats with mode and optional duration"
        },
        "roles": {
          "type": "object",
          "properties": {
            "customer": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Target roles for this course"
            },
            "internal": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Internal audience segments"
            }
          }
        },
        "prerequisites": {
          "type": "object",
          "required": ["courses", "competencies"],
          "properties": {
            "courses": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Required prerequisite courses (must be from validated list)"
            },
            "competencies": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Skills, knowledge, or competencies students should have"
            }
          },
          "description": "Course prerequisites and recommended competencies"
        },
        "ga": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "General availability date (YYYY-MM-DD)"
        },
        "updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Last update date (YYYY-MM-DD)"
        },
        "splunk": {
          "type": "object",
          "required": ["platform"],
          "properties": {
            "platform": {
              "type": "object",
              "required": ["version"],
              "properties": {
                "deployment": {
                  "type": "string",
                  "description": "Deployment type (e.g., 'Cloud', 'Enterprise')"
                },
                "version": {
                  "type": "string",
                  "description": "Splunk version (e.g., '9.4', '10.2.1')"
                }
              }
            }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Plugin name (must match directory in plugins/)"
              },
              "translations": {
                "type": "object",
                "description": "Key-value pairs for translation overrides",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        ]
      },
      "description": "Plugins to load for processing"
    },
    "input": {
      "type": "object",
      "properties": {
        "courseDescription": {
          "type": "string",
          "description": "Custom path to course description markdown file"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "description": "Theme name (defaults to 'splunk-edu')"
        },
        "destination": {
          "type": "string",
          "description": "Custom output directory path"
        },
        "pdfs": {
          "type": "object",
          "properties": {
            "courseDescription": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Custom filename for course description PDF (single format)"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["mode", "title"],
                    "properties": {
                      "mode": {
                        "type": "string",
                        "description": "Mode matching metadata.format[].mode"
                      },
                      "title": {
                        "type": "string",
                        "description": "Custom PDF filename for this mode"
                      }
                    }
                  },
                  "description": "Custom filenames per format mode"
                },
                {
                  "type": "object",
                  "properties": {
                    "filename": {
                      "type": "string",
                      "description": "Custom base filename for PDF(s)"
                    },
                    "format": {
                      "type": "string",
                      "enum": ["combined", "split"],
                      "description": "PDF generation strategy: 'combined' (default, single PDF with table) or 'split' (one PDF per format)"
                    }
                  },
                  "description": "PDF generation configuration object"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["filename", "includes"],
                    "properties": {
                      "filename": {
                        "type": "string",
                        "description": "Custom filename for this PDF"
                      },
                      "includes": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1,
                        "description": "Array of format mode names to include in this PDF (must match metadata.format[].mode values)"
                      }
                    }
                  },
                  "minItems": 1,
                  "description": "Custom format combinations - array of PDF configurations with specific format includes"
                }
              ]
            }
          }
        }
      }
    }
  }
}
